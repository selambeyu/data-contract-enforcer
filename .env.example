# ── LLM Configuration ────────────────────────────────────────────────────────
# Priority: OpenAI → OpenRouter → Ollama → heuristic fallback (no LLM required)
# Only one backend is used per run — first key found wins.

# Option 1: OpenAI  (model: gpt-4o-mini)
OPENAI_API_KEY=

# Option 2: OpenRouter  (OpenAI-compatible — picks any model via openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Option 3: Ollama  (local — start with `ollama serve`)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
